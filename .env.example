# API Keys for PDF Maker
# Copy this file to .env and fill in your keys

# Gemini API Key (for content generation)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Unsplash API Key (for cover images)
# Get yours at: https://unsplash.com/developers → New Application
UNSPLASH_ACCESS_KEY=
